---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/tools/geoduck-dig.css';
import { TOOLS, FIELD_NOTES } from '../scripts/geoduck-dig/geoduck-dig-config';
---

<BaseLayout
  title="Geoduck Dig — Zichao Yang"
  description="A browser game that simulates digging geoduck on a Pacific Northwest tidal flat: read the show, pick a tool, fight sand cave-in and suction, and lift the clam before the tide returns."
>
  <section class="geoduck" data-geoduck-dig>
    <header class="geoduck__header">
      <a href="/" class="geoduck__home-link">
        <i class="ph ph-arrow-left" aria-hidden="true"></i>
        <span>Home</span>
      </a>
      <div class="geoduck__title-block">
        <p class="geoduck__eyebrow">Geoduck Dig</p>
        <h1>Dig a geoduck before the tide takes it back.</h1>
        <p>
          A faithful little sim of intertidal geoduck digging in the Pacific Northwest. Find a
          show, tell a geoduck from a horse clam, then race the sand cave-in, the suction, and the
          incoming tide to lift the clam out whole.
        </p>
      </div>
    </header>

    <!-- Tide + tally HUD -->
    <div class="geoduck__hud">
      <div class="hud__tide">
        <div class="hud__tide-head">
          <span><i class="ph ph-waves" aria-hidden="true"></i> Tide window</span>
          <strong data-tide-time>2:45</strong>
        </div>
        <div class="hud__tide-track">
          <div class="hud__tide-fill" data-tide-fill></div>
        </div>
      </div>
      <ul class="hud__tally">
        <li><span>Geoducks</span><strong data-tally-geoducks>0/3</strong></li>
        <li><span>Haul</span><strong data-tally-weight>0.0 lb</strong></li>
        <li><span>Snapped</span><strong data-tally-snapped>0</strong></li>
        <li><span>Horse clams</span><strong data-tally-horse>0</strong></li>
      </ul>
    </div>

    <p class="geoduck__hint" data-phase-hint>Pick a tool, then click a show on the flat.</p>

    <!-- Tool rack -->
    <div class="geoduck__tools" data-tool-rack>
      {
        TOOLS.map((tool) => (
          <button
            class={`tool-card ${tool.id === 'pvc-tube' ? 'is-active' : ''}`}
            type="button"
            data-tool={tool.id}
          >
            <i class={`ph ${tool.icon}`} aria-hidden="true" />
            <span class="tool-card__name">{tool.label}</span>
            <span class="tool-card__tag">{tool.tagline}</span>
            <span class="tool-card__blurb">{tool.blurb}</span>
          </button>
        ))
      }
    </div>

    <!-- Stage: canvas + overlays -->
    <div class="geoduck__stage">
      <canvas class="geoduck__canvas" data-geoduck-canvas aria-label="Geoduck dig view"></canvas>

      <!-- Inspect overlay -->
      <div class="geoduck-overlay inspect is-hidden" data-inspect>
        <h2 data-inspect-title>Show on the flat</h2>
        <ul class="inspect__clues" data-inspect-clues></ul>
        <p class="inspect__guess" data-inspect-guess></p>
        <div class="inspect__actions">
          <button class="btn btn--primary" type="button" data-inspect-dig>Dig this one</button>
          <button class="btn" type="button" data-inspect-back>Back to flat</button>
        </div>
      </div>

      <!-- Result toast -->
      <div class="geoduck-toast is-hidden" data-result>
        <p data-result-text></p>
      </div>

      <!-- Session end overlay -->
      <div class="geoduck-overlay end is-hidden" data-session-end>
        <div data-end-summary></div>
        <button class="btn btn--primary" type="button" data-restart>Dig again</button>
      </div>
    </div>

    <!-- Dig controls -->
    <div class="geoduck__dig-controls is-hidden" data-dig-controls>
      <div class="dig-readouts">
        <p class="dig-depth" data-depth-read>Dug 0.0 ft · body ≈ 0.0 ft</p>
        <p class="dig-flash" data-dig-flash></p>
      </div>

      <div class="dig-meters">
        <div class="meter">
          <div class="meter__label">
            <span>Suction</span>
            <span class="meter__hint">rock to relieve · R</span>
          </div>
          <div class="meter__track suction" data-suction>
            <div class="meter__fill" data-suction-fill></div>
          </div>
        </div>
        <div class="meter">
          <div class="meter__label">
            <span>Pull tension</span>
            <span class="meter__hint">release in the green</span>
          </div>
          <div class="meter__track pull">
            <div class="pull__green" data-pull-green></div>
            <div class="pull__marker" data-pull-marker></div>
          </div>
        </div>
      </div>

      <div class="dig-buttons">
        <button class="btn btn--dig" type="button" data-btn-dig>
          <i class="ph ph-arrow-fat-down" aria-hidden="true"></i> Dig <small>(hold / Space)</small>
        </button>
        <button class="btn btn--pull" type="button" data-btn-pull>
          <i class="ph ph-arrow-fat-up" aria-hidden="true"></i> Pull <small>(hold / P)</small>
        </button>
        <button class="btn" type="button" data-btn-rock>
          <i class="ph ph-arrows-left-right" aria-hidden="true"></i> Rock <small>(R)</small>
        </button>
        <button class="btn btn--ghost" type="button" data-btn-abandon>Abandon</button>
      </div>
    </div>

    <!-- The real dig -->
    <section class="geoduck__notes">
      <h2>How the real dig works</h2>
      <ul>
        {FIELD_NOTES.map((note) => <li>{note}</li>)}
      </ul>
    </section>
  </section>

  <script>
    import { initGeoduckDig } from '../scripts/geoduck-dig/geoduck-dig-main';
    initGeoduckDig();
  </script>
</BaseLayout>
