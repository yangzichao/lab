---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PhysicsLabShell from '../../components/physics-lab/PhysicsLabShell.astro';
import { findPhysicsLab } from '../../scripts/physics-lab/physics-lab-catalog';

const entry = findPhysicsLab('orbit')!;
---

<BaseLayout title={`${entry.title} — Lab`} description={entry.tagline}>
  <PhysicsLabShell entry={entry}>
    <Fragment slot="readouts">
      <div class="plab__readout"><span>Orbit</span><strong data-readout="classification">Bound ellipse</strong></div>
      <div class="plab__readout"><span>Radius r</span><strong data-readout="radius">180 px</strong></div>
      <div class="plab__readout"><span>Speed v</span><strong data-readout="speed">0.00</strong></div>
      <div class="plab__readout"><span>Energy ε</span><strong data-readout="energy">+0.0</strong></div>
      <div class="plab__readout"><span>Ang. mom. L</span><strong data-readout="angularMomentum">0</strong></div>
      <div class="plab__readout"><span>Eccentricity e</span><strong data-readout="eccentricity">0.000</strong></div>
    </Fragment>

    <form class="plab__panel" slot="controls" aria-label="Orbit lab controls">
      <div class="plab__panel-head">
        <p>Controls</p>
        <h2>Orbit Lab</h2>
      </div>

      <div class="plab__actions">
        <button class="plab__button is-primary" type="button" data-action="toggle">
          <i class="ph ph-pause" aria-hidden="true"></i><span>Pause</span>
        </button>
        <button class="plab__button" type="button" data-action="reset">
          <i class="ph ph-crosshair" aria-hidden="true"></i><span>Launch</span>
        </button>
      </div>

      <div class="plab__presets">
        <button class="plab__preset" type="button" data-preset="circle">Circle</button>
        <button class="plab__preset" type="button" data-preset="ellipse">Ellipse</button>
        <button class="plab__preset" type="button" data-preset="escape">Escape</button>
      </div>

      <label class="plab__toggle">
        <input type="checkbox" data-control="showVectors" checked />
        <span><strong>Velocity & gravity</strong><small>Teal is v, amber is the pull toward the star.</small></span>
      </label>

      <label class="plab__toggle">
        <input type="checkbox" data-control="showOrbit" checked />
        <span><strong>Predicted orbit</strong><small>The conic the current state implies.</small></span>
      </label>

      <label class="plab__toggle">
        <input type="checkbox" data-control="showTrail" checked />
        <span><strong>Trace path</strong><small>Leave a trail behind the body.</small></span>
      </label>

      <label class="plab__field">
        <span class="plab__field-label"><span>Central mass</span><output data-output="centralMass">1.00×</output></span>
        <input type="range" min="0.4" max="2.4" step="0.05" value="1" data-control="centralMass" />
      </label>

      <label class="plab__field">
        <span class="plab__field-label"><span>Launch radius</span><output data-output="launchRadius">180 px</output></span>
        <input type="range" min="120" max="255" step="1" value="180" data-control="launchRadius" />
      </label>

      <label class="plab__field">
        <span class="plab__field-label"><span>Launch speed</span><output data-output="launchSpeed">1.00×</output></span>
        <input type="range" min="0.55" max="1.55" step="0.01" value="1" data-control="launchSpeed" />
      </label>

      <label class="plab__field">
        <span class="plab__field-label"><span>Launch angle</span><output data-output="launchAngle">90°</output></span>
        <input type="range" min="45" max="135" step="1" value="90" data-control="launchAngle" />
      </label>
    </form>
  </PhysicsLabShell>

  <script>
    import { initOrbitLab } from '../../scripts/physics-lab/orbit/orbit-lab';
    initOrbitLab();
  </script>
</BaseLayout>
