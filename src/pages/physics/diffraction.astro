---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PhysicsLabShell from '../../components/physics-lab/PhysicsLabShell.astro';
import { findPhysicsLab } from '../../scripts/physics-lab/physics-lab-catalog';

const entry = findPhysicsLab('diffraction')!;
---

<BaseLayout title={`${entry.title} — Lab`} description={entry.tagline}>
  <PhysicsLabShell entry={entry}>
    <Fragment slot="readouts">
      <div class="plab__readout"><span>单缝首个极小</span><strong data-readout="firstMinimum">sin θ = 0.000</strong></div>
      <div class="plab__readout"><span>主极大间距</span><strong data-readout="maximaSpacing">— (single)</strong></div>
      <div class="plab__readout"><span>缝数</span><strong data-readout="slits">1</strong></div>
      <div class="plab__readout"><span>一级衍射角</span><strong data-readout="firstOrderAngle">— (single)</strong></div>
    </Fragment>

    <form class="plab__panel" slot="controls" aria-label="衍射控制">
      <div class="plab__panel-head">
        <p>控制</p>
        <h2>Diffraction</h2>
      </div>

      <div class="plab__actions">
        <button class="plab__button" type="button" data-action="toggle">
          <i class="ph ph-play" aria-hidden="true"></i><span>播放</span>
        </button>
        <button class="plab__button" type="button" data-action="reset">
          <i class="ph ph-arrow-counter-clockwise" aria-hidden="true"></i><span>重置</span>
        </button>
      </div>

      <div class="plab__presets">
        <button class="plab__preset" type="button" data-preset="single">单缝</button>
        <button class="plab__preset" type="button" data-preset="double">双缝</button>
        <button class="plab__preset" type="button" data-preset="grating">光栅</button>
      </div>

      <label class="plab__field">
        <span class="plab__field-label"><span>缝宽 a</span><output data-output="slitWidth">4.0 µ</output></span>
        <input type="range" min="1" max="14" step="0.5" value="4" data-control="slitWidth" />
      </label>

      <label class="plab__field">
        <span class="plab__field-label"><span>缝间距 d</span><output data-output="slitSpacing">18.0 µ</output></span>
        <input type="range" min="6" max="40" step="0.5" value="18" data-control="slitSpacing" />
      </label>

      <label class="plab__field">
        <span class="plab__field-label"><span>缝数 N</span><output data-output="slitCount">6</output></span>
        <input type="range" min="2" max="12" step="1" value="6" data-control="slitCount" />
      </label>

      <label class="plab__field">
        <span class="plab__field-label"><span>波长 λ</span><output data-output="wavelength">540 nm</output></span>
        <input type="range" min="380" max="720" step="1" value="540" data-control="wavelength" />
      </label>

      <label class="plab__toggle">
        <input type="checkbox" data-control="showEnvelope" checked />
        <span><strong>单缝包络</strong><small>覆盖在细条纹上的虚线 sinc² 包络。</small></span>
      </label>

      <label class="plab__toggle">
        <input type="checkbox" data-control="showScreenBand" checked />
        <span><strong>屏幕色带</strong><small>把强度画成你肉眼会看到的颜色。</small></span>
      </label>
    </form>
  </PhysicsLabShell>

  <script>
    import { initDiffractionLab } from '../../scripts/physics-lab/diffraction/diffraction-lab';
    initDiffractionLab();
  </script>
</BaseLayout>
