---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PhysicsLabShell from '../../components/physics-lab/PhysicsLabShell.astro';
import { findPhysicsLab } from '../../scripts/physics-lab/physics-lab-catalog';

const entry = findPhysicsLab('lens-optics')!;
---

<BaseLayout title={`${entry.title} — Lab`} description={entry.tagline}>
  <PhysicsLabShell entry={entry}>
    <Fragment slot="readouts">
      <div class="plab__readout"><span>像距</span><strong data-readout="imageDistance">0 px</strong></div>
      <div class="plab__readout"><span>放大率</span><strong data-readout="magnification">0.00×</strong></div>
      <div class="plab__readout"><span>像的类型</span><strong data-readout="imageType">real</strong></div>
      <div class="plab__readout"><span>朝向</span><strong data-readout="orientation">inverted</strong></div>
    </Fragment>

    <form class="plab__panel" slot="controls" aria-label="透镜光学控制">
      <div class="plab__panel-head">
        <p>控制</p>
        <h2>Lenses &amp; Refraction</h2>
      </div>

      <div class="plab__actions">
        <button class="plab__button" type="button" data-action="reset">
          <i class="ph ph-arrow-counter-clockwise" aria-hidden="true"></i><span>重置</span>
        </button>
      </div>

      <div class="plab__presets">
        <button class="plab__preset" type="button" data-preset="real">实像</button>
        <button class="plab__preset" type="button" data-preset="magnifier">放大镜</button>
        <button class="plab__preset" type="button" data-preset="diverging">发散</button>
      </div>

      <label class="plab__toggle">
        <input type="checkbox" data-control="showRays" checked />
        <span><strong>主光线</strong><small>确定像的三条光线。</small></span>
      </label>

      <label class="plab__toggle">
        <input type="checkbox" data-control="showFoci" checked />
        <span><strong>焦点标记</strong><small>在两侧标出 F 和 2F。</small></span>
      </label>

      <label class="plab__field">
        <span class="plab__field-label"><span>焦距 f</span><output data-output="focalLength">150 px</output></span>
        <input type="range" min="-260" max="260" step="2" value="150" data-control="focalLength" />
      </label>

      <label class="plab__field">
        <span class="plab__field-label"><span>物距 do</span><output data-output="objectDistance">360 px</output></span>
        <input type="range" min="30" max="420" step="2" value="360" data-control="objectDistance" />
      </label>

      <label class="plab__field">
        <span class="plab__field-label"><span>物高 ho</span><output data-output="objectHeight">110 px</output></span>
        <input type="range" min="20" max="240" step="2" value="110" data-control="objectHeight" />
      </label>
    </form>
  </PhysicsLabShell>

  <script>
    import { initLensOpticsLab } from '../../scripts/physics-lab/lens-optics/lens-optics-lab';
    initLensOpticsLab();
  </script>
</BaseLayout>
