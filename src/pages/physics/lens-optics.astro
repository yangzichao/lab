---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PhysicsLabShell from '../../components/physics-lab/PhysicsLabShell.astro';
import { findPhysicsLab } from '../../scripts/physics-lab/physics-lab-catalog';

const entry = findPhysicsLab('lens-optics')!;
---

<BaseLayout title={`${entry.title} — Lab`} description={entry.tagline}>
  <PhysicsLabShell entry={entry}>
    <Fragment slot="readouts">
      <div class="plab__readout"><span>Image distance</span><strong data-readout="imageDistance">0 px</strong></div>
      <div class="plab__readout"><span>Magnification</span><strong data-readout="magnification">0.00×</strong></div>
      <div class="plab__readout"><span>Image type</span><strong data-readout="imageType">real</strong></div>
      <div class="plab__readout"><span>Orientation</span><strong data-readout="orientation">inverted</strong></div>
    </Fragment>

    <form class="plab__panel" slot="controls" aria-label="Lens optics controls">
      <div class="plab__panel-head">
        <p>Controls</p>
        <h2>Lenses &amp; Refraction</h2>
      </div>

      <div class="plab__actions">
        <button class="plab__button" type="button" data-action="reset">
          <i class="ph ph-arrow-counter-clockwise" aria-hidden="true"></i><span>Reset</span>
        </button>
      </div>

      <div class="plab__presets">
        <button class="plab__preset" type="button" data-preset="real">Real image</button>
        <button class="plab__preset" type="button" data-preset="magnifier">Magnifier</button>
        <button class="plab__preset" type="button" data-preset="diverging">Diverging</button>
      </div>

      <label class="plab__toggle">
        <input type="checkbox" data-control="showRays" checked />
        <span><strong>Principal rays</strong><small>The three rays that fix the image.</small></span>
      </label>

      <label class="plab__toggle">
        <input type="checkbox" data-control="showFoci" checked />
        <span><strong>Focal markers</strong><small>Mark F and 2F on both sides.</small></span>
      </label>

      <label class="plab__field">
        <span class="plab__field-label"><span>Focal length f</span><output data-output="focalLength">150 px</output></span>
        <input type="range" min="-260" max="260" step="2" value="150" data-control="focalLength" />
      </label>

      <label class="plab__field">
        <span class="plab__field-label"><span>Object distance do</span><output data-output="objectDistance">360 px</output></span>
        <input type="range" min="30" max="420" step="2" value="360" data-control="objectDistance" />
      </label>

      <label class="plab__field">
        <span class="plab__field-label"><span>Object height ho</span><output data-output="objectHeight">110 px</output></span>
        <input type="range" min="20" max="240" step="2" value="110" data-control="objectHeight" />
      </label>
    </form>
  </PhysicsLabShell>

  <script>
    import { initLensOpticsLab } from '../../scripts/physics-lab/lens-optics/lens-optics-lab';
    initLensOpticsLab();
  </script>
</BaseLayout>
