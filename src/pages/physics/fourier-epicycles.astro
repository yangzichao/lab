---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PhysicsLabShell from '../../components/physics-lab/PhysicsLabShell.astro';
import { findPhysicsLab } from '../../scripts/physics-lab/physics-lab-catalog';

const entry = findPhysicsLab('fourier-epicycles')!;
---

<BaseLayout title={`${entry.title} — Lab`} description={entry.tagline}>
  <PhysicsLabShell entry={entry}>
    <Fragment slot="readouts">
      <div class="plab__readout"><span>目标波形</span><strong data-readout="waveform">Square</strong></div>
      <div class="plab__readout"><span>项数 (N)</span><strong data-readout="terms">6</strong></div>
      <div class="plab__readout"><span>基频 ω</span><strong data-readout="baseFrequency">1.00 rad/s</strong></div>
      <div class="plab__readout"><span>合成值</span><strong data-readout="value">+0.00</strong></div>
    </Fragment>

    <form class="plab__panel" slot="controls" aria-label="Fourier 周转圆控制">
      <div class="plab__panel-head">
        <p>控制</p>
        <h2>Fourier Epicycles</h2>
      </div>

      <div class="plab__actions">
        <button class="plab__button is-primary" type="button" data-action="toggle">
          <i class="ph ph-pause" aria-hidden="true"></i><span>暂停</span>
        </button>
        <button class="plab__button" type="button" data-action="reset">
          <i class="ph ph-arrow-counter-clockwise" aria-hidden="true"></i><span>重置</span>
        </button>
      </div>

      <div class="plab__presets">
        <button class="plab__preset" type="button" data-preset="square">方波</button>
        <button class="plab__preset" type="button" data-preset="sawtooth">锯齿波</button>
        <button class="plab__preset" type="button" data-preset="triangle">三角波</button>
      </div>

      <label class="plab__toggle">
        <input type="checkbox" data-control="showCircles" checked />
        <span><strong>显示圆</strong><small>每个旋转矢量背后的淡色引导圆。</small></span>
      </label>

      <label class="plab__toggle">
        <input type="checkbox" data-control="showTarget" checked />
        <span><strong>显示目标波</strong><small>理想波形，虚线，用于对比。</small></span>
      </label>

      <label class="plab__field">
        <span class="plab__field-label"><span>谐波数 N</span><output data-output="terms">6</output></span>
        <input type="range" min="1" max="40" step="1" value="6" data-control="terms" />
      </label>

      <label class="plab__field">
        <span class="plab__field-label"><span>速度</span><output data-output="speed">1.00×</output></span>
        <input type="range" min="0.1" max="3" step="0.05" value="1" data-control="speed" />
      </label>
    </form>
  </PhysicsLabShell>

  <script>
    import { initFourierEpicyclesLab } from '../../scripts/physics-lab/fourier-epicycles/fourier-epicycles-lab';
    initFourierEpicyclesLab();
  </script>
</BaseLayout>
