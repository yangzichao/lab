---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PhysicsLabShell from '../../components/physics-lab/PhysicsLabShell.astro';
import { findPhysicsLab } from '../../scripts/physics-lab/physics-lab-catalog';

const entry = findPhysicsLab('fourier-epicycles')!;
---

<BaseLayout title={`${entry.title} — Lab`} description={entry.tagline}>
  <PhysicsLabShell entry={entry}>
    <Fragment slot="readouts">
      <div class="plab__readout"><span>Target wave</span><strong data-readout="waveform">Square</strong></div>
      <div class="plab__readout"><span>Terms (N)</span><strong data-readout="terms">6</strong></div>
      <div class="plab__readout"><span>Base ω</span><strong data-readout="baseFrequency">1.00 rad/s</strong></div>
      <div class="plab__readout"><span>Synthesised value</span><strong data-readout="value">+0.00</strong></div>
    </Fragment>

    <form class="plab__panel" slot="controls" aria-label="Fourier epicycles controls">
      <div class="plab__panel-head">
        <p>Controls</p>
        <h2>Fourier Epicycles</h2>
      </div>

      <div class="plab__actions">
        <button class="plab__button is-primary" type="button" data-action="toggle">
          <i class="ph ph-pause" aria-hidden="true"></i><span>Pause</span>
        </button>
        <button class="plab__button" type="button" data-action="reset">
          <i class="ph ph-arrow-counter-clockwise" aria-hidden="true"></i><span>Reset</span>
        </button>
      </div>

      <div class="plab__presets">
        <button class="plab__preset" type="button" data-preset="square">Square</button>
        <button class="plab__preset" type="button" data-preset="sawtooth">Sawtooth</button>
        <button class="plab__preset" type="button" data-preset="triangle">Triangle</button>
      </div>

      <label class="plab__toggle">
        <input type="checkbox" data-control="showCircles" checked />
        <span><strong>Show circles</strong><small>The faint guide circle behind each rotating vector.</small></span>
      </label>

      <label class="plab__toggle">
        <input type="checkbox" data-control="showTarget" checked />
        <span><strong>Show target wave</strong><small>The ideal waveform, dashed, for comparison.</small></span>
      </label>

      <label class="plab__field">
        <span class="plab__field-label"><span>Harmonics N</span><output data-output="terms">6</output></span>
        <input type="range" min="1" max="40" step="1" value="6" data-control="terms" />
      </label>

      <label class="plab__field">
        <span class="plab__field-label"><span>Speed</span><output data-output="speed">1.00×</output></span>
        <input type="range" min="0.1" max="3" step="0.05" value="1" data-control="speed" />
      </label>
    </form>
  </PhysicsLabShell>

  <script>
    import { initFourierEpicyclesLab } from '../../scripts/physics-lab/fourier-epicycles/fourier-epicycles-lab';
    initFourierEpicyclesLab();
  </script>
</BaseLayout>
