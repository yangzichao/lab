---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PhysicsLabShell from '../../components/physics-lab/PhysicsLabShell.astro';
import { findPhysicsLab } from '../../scripts/physics-lab/physics-lab-catalog';

const entry = findPhysicsLab('three-body')!;
---

<BaseLayout title={`${entry.title} — Lab`} description={entry.tagline}>
  <PhysicsLabShell entry={entry}>
    <Fragment slot="readouts">
      <div class="plab__readout"><span>时间</span><strong data-readout="time">0.0 s</strong></div>
      <div class="plab__readout"><span>总能量</span><strong data-readout="energy">+0.000</strong></div>
      <div class="plab__readout"><span>总动量</span><strong data-readout="momentum">0.000</strong></div>
      <div class="plab__readout"><span>状态</span><strong data-readout="status">Bounded</strong></div>
    </Fragment>

    <form class="plab__panel" slot="controls" aria-label="三体控制">
      <div class="plab__panel-head">
        <p>控制</p>
        <h2>Three-Body Problem</h2>
      </div>

      <div class="plab__actions">
        <button class="plab__button is-primary" type="button" data-action="toggle">
          <i class="ph ph-pause" aria-hidden="true"></i><span>暂停</span>
        </button>
        <button class="plab__button" type="button" data-action="reset">
          <i class="ph ph-arrow-counter-clockwise" aria-hidden="true"></i><span>重置</span>
        </button>
      </div>

      <div class="plab__presets">
        <button class="plab__preset" type="button" data-preset="figure8">8 字轨道</button>
        <button class="plab__preset" type="button" data-preset="chaos">混沌</button>
        <button class="plab__preset" type="button" data-preset="triangle">三角</button>
      </div>

      <label class="plab__toggle">
        <input type="checkbox" data-control="showTrails" checked />
        <span><strong>显示轨迹</strong><small>每个天体身后留下的渐隐轨迹。</small></span>
      </label>

      <label class="plab__toggle">
        <input type="checkbox" data-control="showVectors" />
        <span><strong>显示速度矢量</strong><small>每个天体一支 teal 箭头。</small></span>
      </label>

      <label class="plab__toggle">
        <input type="checkbox" data-control="showCenterOfMass" />
        <span><strong>显示质心</strong><small>应保持不动——动量守恒。</small></span>
      </label>

      <label class="plab__field">
        <span class="plab__field-label"><span>速度</span><output data-output="speed">1.00×</output></span>
        <input type="range" min="0.2" max="3" step="0.05" value="1" data-control="speed" />
      </label>

      <label class="plab__field">
        <span class="plab__field-label"><span>扰动</span><output data-output="perturbation">0.50%</output></span>
        <input type="range" min="0" max="5" step="0.05" value="0.5" data-control="perturbation" />
      </label>
    </form>
  </PhysicsLabShell>

  <script>
    import { initThreeBodyLab } from '../../scripts/physics-lab/three-body/three-body-lab';
    initThreeBodyLab();
  </script>
</BaseLayout>
