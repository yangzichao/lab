---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SystemDesignLabNav from '../../components/system-design-lab/SystemDesignLabNav.astro';
import SystemDesignConstraintLab from '../../components/system-design-lab/SystemDesignConstraintLab.astro';
import { searchAutocompleteLabDefinition } from '../../scripts/system-design-lab/labs/search-autocomplete-lab';
import { getSystemDesignLabPage } from '../../scripts/system-design-lab/system-design-pages';

const page = getSystemDesignLabPage('search-autocomplete');
---

