---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SystemDesignLabNav from '../../components/system-design-lab/SystemDesignLabNav.astro';
import SystemDesignConstraintLab from '../../components/system-design-lab/SystemDesignConstraintLab.astro';
import { urlShortenerLabDefinition } from '../../scripts/system-design-lab/labs/url-shortener-lab';
import { getSystemDesignLabPage } from '../../scripts/system-design-lab/system-design-pages';

const page = getSystemDesignLabPage('url-shortener');
---

<BaseLayout title={page.pageTitle} description={page.metaDescription}>
  <SystemDesignLabNav current="url-shortener" />
  <SystemDesignConstraintLab lab={urlShortenerLabDefinition} />
</BaseLayout>
