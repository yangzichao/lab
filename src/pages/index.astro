---
import BaseLayout from '../layouts/BaseLayout.astro';
import { systemDesignLabPages } from '../scripts/system-design-lab/system-design-pages';

const labs = [
  {
    title: 'Quaternion Rotation Lab',
    href: '/quaternions/',
    description:
      '一个交互式 3D 教学 lab，讲 quaternion 旋转、SLERP、SU(2) double cover、Pauli matrices 以及 Bloch sphere 上的运动。',
  },
  {
    title: 'Sandbox Physics · 物理实验',
    href: 'https://sandboxphysics.com/',
    description:
      '物理仿真与量子实验已经迁移到独立站点 Sandbox Physics，继续提供中英文交互式学习体验。',
  },
  ...systemDesignLabPages.map((page) => ({
    title: page.cardTitle,
    href: `/system-design/${page.slug}/`,
    description: page.cardDescription,
  })),
];
---

<BaseLayout
  title="Lab — Zichao Yang"
  description="Zichao Yang 的交互式教学 lab 与小玩具：quaternion 旋转与系统设计演练场。一切都在你的浏览器里运行。"
>
  <header class="lab-index__header">
    <a href="https://zichaoyang.com/" class="lab-index__back">&larr; zichaoyang.com</a>
    <h1>Lab</h1>
    <p>
      交互式的 lab 与小玩具 —— 一些为了搞懂更大的东西而做的小东西。
      一切都完全在你的浏览器里运行。
    </p>
  </header>

  <ul class="lab-index__grid">
    {
      labs.map((lab) => (
        <li>
          <a href={lab.href} class="lab-index__card">
            <h2>{lab.title}</h2>
            <p>{lab.description}</p>
            <span class="lab-index__go">打开 &rarr;</span>
          </a>
        </li>
      ))
    }
  </ul>
</BaseLayout>

<style>
  .lab-index__header {
    margin: 3.5rem 0 2.5rem;
  }

  .lab-index__back {
    display: inline-block;
    margin-bottom: 1.25rem;
    color: var(--color-text-muted);
    text-decoration: none;
    font-size: 0.9rem;
    transition: color var(--transition);
  }

  .lab-index__back:hover {
    color: var(--color-text-main);
  }

  .lab-index__header h1 {
    margin: 0 0 0.5rem;
    font-size: 2.5rem;
    font-weight: 700;
    letter-spacing: -0.02em;
  }

  .lab-index__header p {
    margin: 0;
    max-width: 40rem;
    color: var(--color-text-muted);
    line-height: 1.6;
  }

  .lab-index__grid {
    list-style: none;
    margin: 0 0 4rem;
    padding: 0;
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 22rem), 1fr));
  }

  .lab-index__card {
    display: flex;
    flex-direction: column;
    height: 100%;
    padding: 1.5rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    background: var(--color-card-background);
    text-decoration: none;
    color: inherit;
    transition:
      background var(--transition),
      border-color var(--transition),
      transform var(--transition);
  }

  .lab-index__card:hover {
    background: var(--color-card-hover);
    border-color: var(--color-text-muted);
    transform: translateY(-2px);
  }

  .lab-index__card h2 {
    margin: 0 0 0.5rem;
    font-size: 1.2rem;
    font-weight: 600;
  }

  .lab-index__card p {
    margin: 0 0 1.25rem;
    flex: 1;
    color: var(--color-text-muted);
    line-height: 1.55;
    font-size: 0.95rem;
  }

  .lab-index__go {
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--color-accent);
  }
</style>
