---
import BaseLayout from '../layouts/BaseLayout.astro';
import MathFormula from '../components/math/MathFormula.astro';
import '../styles/tools/quaternion-lab.css';

const focusModes = [
  {
    id: 'full',
    icon: 'ph-circles-three-plus',
    label: 'Full',
  },
  {
    id: 'body',
    icon: 'ph-cube',
    label: 'SO(3)',
  },
  {
    id: 'spinor',
    icon: 'ph-spiral',
    label: 'SU(2)',
  },
  {
    id: 'bloch',
    icon: 'ph-atom',
    label: 'Bloch',
  },
];

const axisPresets = [
  { id: 'x', label: 'X' },
  { id: 'y', label: 'Y' },
  { id: 'z', label: 'Z' },
  { id: 'diagonal', label: 'Diag' },
];

const conceptCards = [
  {
    title: '1. 单位 quaternion 就是一个旋转手柄',
    body:
      '单位 quaternion 的 vector part 指向 rotation axis，scalar part 存着 half angle。',
    formulaLatex:
      'q = \\cos\\!\\left(\\frac{\\theta}{2}\\right) + \\hat{\\mathbf u}\\,\\sin\\!\\left(\\frac{\\theta}{2}\\right)',
  },
  {
    title: '2. 用 conjugation 旋转向量',
    body:
      '把 3D 向量写成纯 quaternion，旋转结果就是下面这个 conjugation 的 vector part。',
    formulaLatex: "p' = q\\,p\\,q^{-1}",
  },
  {
    title: '3. 组合就是乘法',
    body:
      '先做旋转 A 再做旋转 B，不是简单地把角度相加，而是 quaternion 乘法，所以顺序很重要。',
    formulaLatex: 'q_{\\mathrm{total}} = q_B q_A',
  },
  {
    title: '4. q 和 -q 描述的是同一个 3D 姿态',
    body:
      '立方体转 360 度就回到原样，但 spinor 的符号翻转了。SU(2) 这个对象要转 720 度才能回到初始符号。',
    formulaLatex: '\\mathrm{SO}(3) \\cong \\mathrm{SU}(2) / \\{\\pm I\\}',
  },
];

const applicationCards = [
  {
    title: '图形与游戏',
    body:
      '相机朝向、角色骨骼和物体动画都用 quaternion，因为它能避免 gimbal lock，还能用 SLERP 平滑插值。',
  },
  {
    title: '机器人与导航',
    body:
      '无人机、手机和机械臂把 IMU 数据融合成姿态 quaternion，再转换成控制坐标系下的旋转。',
  },
  {
    title: '量子力学',
    body:
      'Pauli matrix 生成 SU(2)。一个 single-qubit gate 或 spin-1/2 旋转正是单位 quaternion 的矩阵孪生体。',
    formulaLatex: 'U = \\exp\\!\\left(-\\frac{i\\theta}{2}\\,\\hat{\\mathbf n}\\!\\cdot\\!\\boldsymbol{\\sigma}\\right)',
  },
  {
    title: '物理可视化',
    body:
      'Bloch sphere 上的运动、角动量、刚体姿态，都能用同一套 axis-angle 和 double-cover 的思路来展示。',
  },
];

const staticFormulaLatex = {
  unitQuaternion: 'q = w + x\\mathbf i + y\\mathbf j + z\\mathbf k',
  rotationConjugation: "p' = qpq^{-1}",
  initialQuaternion: 'q = (1.000, 0.000, 0.000, 0.000)',
  initialAxisAngle:
    'q = \\cos(36.0^{\\circ}) + (0.35\\mathbf i + 0.72\\mathbf j + 0.59\\mathbf k)\\sin(36.0^{\\circ})',
  identityMatrix: '\\begin{pmatrix} 1.000 & 0.000 \\\\ 0.000 & 1.000 \\end{pmatrix}',
  quaternionMatrixMap: 'U(q) = wI - i(x\\sigma_x + y\\sigma_y + z\\sigma_z)',
  unitNorm: 'w^2 + x^2 + y^2 + z^2 = 1',
  spinorRotation:
    'U = \\exp\\!\\left(-\\frac{i\\theta}{2}\\,\\hat{\\mathbf n}\\!\\cdot\\!\\boldsymbol{\\sigma}\\right)',
  sigmaX: '\\sigma_x',
  sigmaY: '\\sigma_y',
  sigmaZ: '\\sigma_z',
  pauliX: '\\begin{pmatrix} 0 & 1 \\\\ 1 & 0 \\end{pmatrix}',
  pauliY: '\\begin{pmatrix} 0 & -i \\\\ i & 0 \\end{pmatrix}',
  pauliZ: '\\begin{pmatrix} 1 & 0 \\\\ 0 & -1 \\end{pmatrix}',
};
---

<BaseLayout
  title="Quaternion Rotation Lab - Zichao Yang"
  description="一个讲 quaternion、3D rotation、Pauli matrix、SU(2) 和 Bloch sphere 的交互式 3D 教学页面。"
>
  <section class="quaternion-lab" data-quaternion-lab>
    <header class="quaternion-lab__header">
      <a href="/" class="quaternion-lab__home-link">
        <i class="ph ph-arrow-left" aria-hidden="true"></i>
        <span>首页</span>
      </a>

      <div class="quaternion-lab__title-block">
        <p class="quaternion-lab__eyebrow">Quaternion Rotation Lab</p>
        <h1>同一个对象，两层 cover，三种看旋转的方式。</h1>
        <p>
          一个可视化的 lab，讲单位 quaternion
          <MathFormula expression={staticFormulaLatex.unitQuaternion} />、它的 3D rotation
          <MathFormula expression={staticFormulaLatex.rotationConjugation} />，以及同一个 SU(2) 变换的
          Pauli-matrix 形式。
        </p>
      </div>
    </header>

    <section class="quaternion-stage" aria-label="Quaternion 3D 模拟器">
      <div class="quaternion-stage__visual" data-quaternion-scene>
        <div class="quaternion-stage__fallback">正在加载 3D quaternion 场景...</div>
      </div>

      <aside class="quaternion-stage__control-panel" aria-label="Quaternion 控制面板">
        <div class="quaternion-control-panel__header">
          <p>实时 Quaternion</p>
          <strong data-quaternion-readout="quaternion">
            <MathFormula expression={staticFormulaLatex.initialQuaternion} />
          </strong>
        </div>

        <div class="quaternion-readout-grid" aria-label="旋转读数">
          <span>
            <small>Axis（轴）</small>
            <strong data-quaternion-readout="axis">(0.00, 1.00, 0.00)</strong>
          </span>
          <span>
            <small>Spinor 相位</small>
            <strong data-quaternion-readout="spinorPhase">0 deg</strong>
          </span>
        </div>

        <div class="quaternion-button-row">
          <button class="quaternion-button is-primary" type="button" data-quaternion-action="toggle">
            <i class="ph ph-pause" aria-hidden="true"></i>
            <span>暂停</span>
          </button>
          <button class="quaternion-button" type="button" data-quaternion-action="reset">
            <i class="ph ph-arrow-counter-clockwise" aria-hidden="true"></i>
            <span>重置</span>
          </button>
        </div>

        <div class="quaternion-segmented" role="group" aria-label="3D focus 模式">
          {
            focusModes.map((mode, index) => (
              <button
                type="button"
                class={index === 0 ? 'is-active' : ''}
                data-quaternion-focus={mode.id}
                aria-pressed={index === 0 ? 'true' : 'false'}
              >
                <i class={`ph ${mode.icon}`} aria-hidden="true"></i>
                <span>{mode.label}</span>
              </button>
            ))
          }
        </div>

        <label class="quaternion-range">
          <span>
            <strong>旋转角度</strong>
            <output data-quaternion-output="angle">72 deg</output>
          </span>
          <input
            type="range"
            min="0"
            max="720"
            step="1"
            value="72"
            data-quaternion-control="angle"
          />
        </label>

        <label class="quaternion-range">
          <span>
            <strong>轴 x</strong>
            <output data-quaternion-output="axisX">0.35</output>
          </span>
          <input
            type="range"
            min="-1"
            max="1"
            step="0.01"
            value="0.35"
            data-quaternion-control="axisX"
          />
        </label>

        <label class="quaternion-range">
          <span>
            <strong>轴 y</strong>
            <output data-quaternion-output="axisY">0.72</output>
          </span>
          <input
            type="range"
            min="-1"
            max="1"
            step="0.01"
            value="0.72"
            data-quaternion-control="axisY"
          />
        </label>

        <label class="quaternion-range">
          <span>
            <strong>轴 z</strong>
            <output data-quaternion-output="axisZ">0.59</output>
          </span>
          <input
            type="range"
            min="-1"
            max="1"
            step="0.01"
            value="0.59"
            data-quaternion-control="axisZ"
          />
        </label>

        <label class="quaternion-range">
          <span>
            <strong>动画速度</strong>
            <output data-quaternion-output="speed">26 deg/s</output>
          </span>
          <input
            type="range"
            min="0"
            max="90"
            step="1"
            value="26"
            data-quaternion-control="speed"
          />
        </label>

        <div class="quaternion-presets" aria-label="Axis 预设">
          {
            axisPresets.map((preset) => (
              <button type="button" data-quaternion-axis-preset={preset.id}>{preset.label}</button>
            ))
          }
        </div>

        <label class="quaternion-toggle">
          <input type="checkbox" data-quaternion-control="showGhosts" checked />
          <span>
            <strong>显示 SLERP ghosts</strong>
            <small>从 identity 到 q 之间的中间姿态。</small>
          </span>
        </label>
      </aside>
    </section>

    <section class="quaternion-live-math" aria-label="实时 quaternion 数学">
      <article class="quaternion-equation-block">
        <p>Axis-angle 形式</p>
        <div class="quaternion-dynamic-formula" data-quaternion-readout="axisAngleFormula">
          <MathFormula
            expression={staticFormulaLatex.initialAxisAngle}
            display
          />
        </div>
      </article>

      <article class="quaternion-equation-block">
        <p>Pauli-matrix 形式</p>
        <div
          class="quaternion-matrix"
          data-quaternion-readout="pauliMatrix"
          aria-label="由 quaternion 生成的 SU(2) 矩阵"
        >
          <MathFormula
            expression={staticFormulaLatex.identityMatrix}
            display
          />
        </div>
      </article>
    </section>

    <section class="quaternion-teaching" aria-label="Quaternion 教学笔记">
      <div class="quaternion-section-heading">
        <p>教学路径</p>
        <h2>从 quaternion 数到 Pauli matrix。</h2>
      </div>

      <div class="quaternion-concept-grid">
        {
          conceptCards.map((card) => (
            <article class="quaternion-concept-card">
              <h3>{card.title}</h3>
              <p>{card.body}</p>
              <MathFormula expression={card.formulaLatex} display />
            </article>
          ))
        }
      </div>
    </section>

    <section class="quaternion-pauli-section" aria-label="Quaternion 与 Pauli matrix 的联系">
      <div class="quaternion-pauli-copy">
        <p class="quaternion-lab__eyebrow">Pauli 之桥</p>
        <h2>单位 quaternion 和 SU(2) 用的是同样四个实数自由度。</h2>
        <p>
          把单位 quaternion 打包进一个复矩阵：
          <MathFormula expression={staticFormulaLatex.quaternionMatrixMap} />。
          因为 <MathFormula expression={staticFormulaLatex.unitNorm} />，这个矩阵是 unitary 的，
          行列式为一。这正好就是 SU(2)。
        </p>
        <p>
          这就是为什么一个 3D rotation 既可以描述成 quaternion 作用在向量上，
          也可以描述成 Pauli-matrix 指数作用在 spinor 上：
          <MathFormula expression={staticFormulaLatex.spinorRotation} />。
          half angle 是两边共享的线索。
        </p>
      </div>

      <div class="quaternion-pauli-table" aria-label="Pauli 矩阵">
        <article>
          <strong><MathFormula expression={staticFormulaLatex.sigmaX} /></strong>
          <MathFormula expression={staticFormulaLatex.pauliX} display />
        </article>
        <article>
          <strong><MathFormula expression={staticFormulaLatex.sigmaY} /></strong>
          <MathFormula expression={staticFormulaLatex.pauliY} display />
        </article>
        <article>
          <strong><MathFormula expression={staticFormulaLatex.sigmaZ} /></strong>
          <MathFormula expression={staticFormulaLatex.pauliZ} display />
        </article>
      </div>
    </section>

    <section class="quaternion-applications" aria-label="Quaternion 应用">
      <div class="quaternion-section-heading">
        <p>应用</p>
        <h2>同一套数学还会出现在哪里。</h2>
      </div>

      <div class="quaternion-application-grid">
        {
          applicationCards.map((card) => (
            <article class="quaternion-application-card">
              <h3>{card.title}</h3>
              <p>{card.body}</p>
              {'formulaLatex' in card && card.formulaLatex && (
                <MathFormula expression={card.formulaLatex} display />
              )}
            </article>
          ))
        }
      </div>
    </section>
  </section>

  <script>
    import { initQuaternionLab } from '../scripts/quaternion-lab/quaternion-lab-main';
    initQuaternionLab();
  </script>
</BaseLayout>
