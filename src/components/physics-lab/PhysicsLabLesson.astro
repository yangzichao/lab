---
import '../../styles/physics-lab/lesson.css';
import type { PhysicsLabLocale } from '../../scripts/physics-lab/physics-lab-i18n';
import type { PhysicsLabLesson } from '../../scripts/physics-lab/lessons/physics-lab-lesson-types';
import MathFormula from '../math/MathFormula.astro';

interface Props {
  lesson: PhysicsLabLesson;
  locale: PhysicsLabLocale;
}

const { lesson, locale } = Astro.props;
const copy = {
  zh: {
    eyebrow: '物理教程',
    model: '核心数学模型',
    procedure: '动手实验',
    observation: '应该观察到：',
    takeaway: '物理结论',
  },
  en: {
    eyebrow: 'Physics tutorial',
    model: 'Core mathematical model',
    procedure: 'Run the experiment',
    observation: 'What to observe:',
    takeaway: 'Physical conclusion',
  },
}[locale];
---

<section class="plab-lesson" aria-labelledby="plab-lesson-title">
  <header class="plab-lesson__header">
    <p>{copy.eyebrow}</p>
    <h2 id="plab-lesson-title">{lesson.title}</h2>
    <span>{lesson.introduction}</span>
  </header>

  <div class="plab-lesson__section">
    <h3>{copy.model}</h3>
    <div class="plab-lesson__formula-grid">
      {
        lesson.formulas.map((formula) => (
          <article class="plab-lesson__formula-card">
            <h4>{formula.title}</h4>
            <MathFormula expression={formula.expressionLatex} display />
            <p>{formula.explanation}</p>
          </article>
        ))
      }
    </div>
  </div>

  <div class="plab-lesson__section plab-lesson__procedure">
    <h3>{copy.procedure}</h3>
    <ol>
      {
        lesson.steps.map((step, index) => (
          <li>
            <span class="plab-lesson__step-number">{String(index + 1).padStart(2, '0')}</span>
            <div>
              <h4>{step.title}</h4>
              <p>{step.instruction}</p>
              <small><strong>{copy.observation}</strong> {step.observation}</small>
            </div>
          </li>
        ))
      }
    </ol>
  </div>

  <aside class="plab-lesson__takeaway">
    <span>{copy.takeaway}</span>
    <p>{lesson.takeaway}</p>
  </aside>
</section>
