---
import type { PhysicsLabLocale } from '../../../scripts/physics-lab/physics-lab-i18n';
import { getLigoScientificExplanation } from '../../../scripts/physics-lab/ligo/ligo-scientific-copy';
import { ligoSceneIds } from '../../../scripts/physics-lab/ligo/ligo-scene-types';

interface Props {
  locale: PhysicsLabLocale;
}

const { locale } = Astro.props;
const copy = {
  zh: {
    eyebrow: '科学解释',
    title: '把画面读成物理过程',
    whatHappens: '发生了什么',
    causalChain: '因果链',
    equation: '数学模型',
    variables: '符号',
    boundary: '模型边界',
    sources: '依据与延伸阅读',
  },
  en: {
    eyebrow: 'Scientific explanation',
    title: 'Read the picture as a physical process',
    whatHappens: 'What is happening',
    causalChain: 'Causal chain',
    equation: 'Mathematical model',
    variables: 'Symbols',
    boundary: 'Model boundary',
    sources: 'Sources and further reading',
  },
}[locale];

const sourceLinks = [
  {
    href: 'https://www.ligo.caltech.edu/LA/page/ligos-ifo',
    label: locale === 'en' ? "LIGO's Interferometer" : 'LIGO 干涉仪原理',
  },
  {
    href: 'https://ligo.org/science-summaries/GW150914Detector/',
    label: locale === 'en' ? 'Advanced LIGO and GW150914' : 'Advanced LIGO 与 GW150914',
  },
  {
    href: 'https://dcc.ligo.org/public/0094/G1200743/001/G1200743v1_part3.pdf',
    label: locale === 'en' ? 'Advanced LIGO DC readout' : 'Advanced LIGO DC readout',
  },
];
---

<section class="ligo-science" data-ligo-science-panel aria-labelledby="ligo-science-title">
  <header class="ligo-science__header">
    <p>{copy.eyebrow}</p>
    <h2 id="ligo-science-title">{copy.title}</h2>
  </header>

  <div class="ligo-science__steps" aria-live="polite">
    {
      ligoSceneIds.map((sceneId, index) => {
        const explanation = getLigoScientificExplanation(locale, sceneId);
        return (
          <article data-ligo-science-step={sceneId} hidden={index !== 0}>
            <div class="ligo-science__narrative">
              <p class="ligo-science__label">{copy.whatHappens}</p>
              <h3>{explanation.question}</h3>
              <p class="ligo-science__answer">{explanation.answer}</p>

              <p class="ligo-science__label">{copy.causalChain}</p>
              <ol class="ligo-science__chain">
                {explanation.causalSteps.map((step, stepIndex) => (
                  <li>
                    <span>{stepIndex + 1}</span>
                    <div>
                      <strong>{step.label}</strong>
                      <small>{step.detail}</small>
                    </div>
                  </li>
                ))}
              </ol>
            </div>

            <div class="ligo-science__math">
              <p class="ligo-science__label">{copy.equation}</p>
              <div
                class="ligo-science__equation"
                role="img"
                aria-label={explanation.equationAriaLabel}
                set:html={explanation.equationHtml}
              />

              <p class="ligo-science__label">{copy.variables}</p>
              <dl class="ligo-science__variables">
                {explanation.variables.map((variable) => (
                  <div>
                    <dt>{variable.symbol}</dt>
                    <dd>{variable.definition}</dd>
                  </div>
                ))}
              </dl>

              <p class="ligo-science__boundary">
                <strong>{copy.boundary}</strong>
                <span>{explanation.modelBoundary}</span>
              </p>
            </div>
          </article>
        );
      })
    }
  </div>

  <footer class="ligo-science__sources">
    <span>{copy.sources}</span>
    {sourceLinks.map((source) => (
      <a href={source.href} target="_blank" rel="noreferrer">{source.label}</a>
    ))}
  </footer>
</section>
