---
import '../../styles/physics-lab/physics-lab.css';
import { getPhysicsLabCatalog, type PhysicsLabEntry } from '../../scripts/physics-lab/physics-lab-catalog';
import {
  getAlternatePhysicsLabLocale,
  getLocalizedPhysicsLabPath,
  normalizePhysicsLabLocale,
  type PhysicsLabLocale,
} from '../../scripts/physics-lab/physics-lab-i18n';

interface Props {
  entry: PhysicsLabEntry;
  locale?: PhysicsLabLocale;
  entries?: PhysicsLabEntry[];
  alternateHref?: string;
  suite?: 'physics' | 'quantum';
}

const { entry } = Astro.props;
const locale = normalizePhysicsLabLocale(Astro.props.locale ?? entry.locale);
const labs = Astro.props.entries ?? getPhysicsLabCatalog(locale);
const suite = Astro.props.suite ?? 'physics';
const alternateLocale = getAlternatePhysicsLabLocale(locale);
const currentLanguageLabel = locale === 'en' ? 'EN' : '中文';
const alternateLanguageLabel = alternateLocale === 'en' ? 'EN' : '中文';
const backLabel = locale === 'en' ? 'All labs' : '所有 lab';
const navAriaLabel =
  suite === 'quantum'
    ? locale === 'en'
      ? 'Quantum labs'
      : '量子实验'
    : locale === 'en'
      ? 'Physics labs'
      : '物理 lab';
const languageToggleLabel =
  locale === 'en' ? 'Switch language to Chinese' : '切换语言到 English';
const alternateHref =
  Astro.props.alternateHref ?? getLocalizedPhysicsLabPath(entry.slug, alternateLocale);
const currentSuiteLabel =
  suite === 'quantum'
    ? locale === 'en'
      ? 'Quantum labs'
      : '量子实验'
    : locale === 'en'
      ? 'Physics labs'
      : '物理实验';
const relatedSuiteLabel =
  suite === 'quantum'
    ? locale === 'en'
      ? 'Classical physics'
      : '经典物理'
    : locale === 'en'
      ? 'Quantum labs'
      : '量子实验';
const relatedSuiteHref =
  suite === 'quantum'
    ? locale === 'en'
      ? '/en/physics/wave-interference/'
      : '/physics/wave-interference/'
    : locale === 'en'
      ? '/en/physics/quantum/qubit-state/'
      : '/physics/quantum/qubit-state/';
const canvasAriaLabel =
  locale === 'en' ? `${entry.title} simulation canvas` : `${entry.title} 仿真画布`;
---

<section class="plab" data-lab={entry.slug} data-locale={locale} data-lab-suite={suite}>
  <header class="plab__head">
    <div class="plab__topbar">
      <a class="plab__back" href="/">
        <i class="ph ph-arrow-left" aria-hidden="true"></i>
        <span>{backLabel}</span>
      </a>

      <a
        class="plab__language-toggle"
        href={alternateHref}
        aria-label={languageToggleLabel}
      >
        <span class="plab__language-toggle-active">{currentLanguageLabel}</span>
        <span class="plab__language-toggle-divider" aria-hidden="true">/</span>
        <span>{alternateLanguageLabel}</span>
      </a>
    </div>

    <div class="plab__suite-tabs" aria-label={locale === 'en' ? 'Lab collections' : '实验分类'}>
      <span aria-current="page">{currentSuiteLabel}</span>
      <a href={relatedSuiteHref}>{relatedSuiteLabel}</a>
    </div>

    <p class="plab__eyebrow">{entry.eyebrow}</p>
    <h1 class="plab__title">{entry.title}</h1>
    <p class="plab__lede">{entry.description}</p>

    <nav class="plab__switcher" aria-label={navAriaLabel}>
      {
        labs.map((lab) => (
          <a
            class={`plab__switcher-link ${lab.slug === entry.slug ? 'is-current' : ''}`}
            href={lab.href}
            aria-current={lab.slug === entry.slug ? 'page' : undefined}
          >
            <i class={`ph ${lab.icon}`} aria-hidden="true"></i>
            <span>{lab.title}</span>
          </a>
        ))
      }
    </nav>
  </header>

  <div class="plab__workspace">
    <div class="plab__stage-col">
      <div class="plab__stage">
        <canvas
          class="plab__canvas"
          width="900"
          height="560"
          data-stage-canvas
          aria-label={canvasAriaLabel}></canvas>
      </div>
      <div class="plab__readouts">
        <slot name="readouts" />
      </div>
      <slot name="lesson" />
    </div>

    <aside class="plab__controls-col">
      <slot name="controls" />
      <p class="plab__notice">
        <i class="ph ph-lightbulb" aria-hidden="true"></i>
        <span>{entry.notice}</span>
      </p>
    </aside>
  </div>
</section>
