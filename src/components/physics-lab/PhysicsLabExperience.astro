---
import type { PhysicsLabEntry } from '../../scripts/physics-lab/physics-lab-catalog';
import type { PhysicsLabLocale } from '../../scripts/physics-lab/physics-lab-i18n';
import type { PhysicsLabPage } from '../../scripts/physics-lab/physics-lab-pages';
import { getPhysicsLabLesson } from '../../scripts/physics-lab/lessons/physics-lab-lesson-registry';
import MathFormula from '../math/MathFormula.astro';
import PhysicsLabLesson from './PhysicsLabLesson.astro';
import LigoScientificExplanation from './ligo/LigoScientificExplanation.astro';
import PhysicsLabShell from './PhysicsLabShell.astro';

interface Props {
  entry: PhysicsLabEntry;
  page: PhysicsLabPage;
  locale: PhysicsLabLocale;
  entries?: PhysicsLabEntry[];
  alternateHref?: string;
  suite?: 'physics' | 'quantum';
}

const { entry, page, locale, entries, alternateHref, suite = 'physics' } = Astro.props;
const lesson = getPhysicsLabLesson(entry.slug, locale, suite);
---

<PhysicsLabShell
  entry={entry}
  locale={locale}
  entries={entries}
  alternateHref={alternateHref}
  suite={suite}
>
  <Fragment slot="readouts">
    {
      page.readouts.map((readout) => (
        <div class="plab__readout">
          <span>{readout.label}</span>
          <strong data-readout={readout.id}>{readout.initialValue}</strong>
        </div>
      ))
    }
  </Fragment>

  <Fragment slot="lesson">
    {lesson && <PhysicsLabLesson lesson={lesson} locale={locale} />}
    {entry.slug === 'ligo-interferometer' && <LigoScientificExplanation locale={locale} />}
  </Fragment>

  <form class="plab__panel" slot="controls" aria-label={page.controls.ariaLabel}>
    <div class="plab__panel-head">
      <p>{page.controls.eyebrow}</p>
      <h2>{page.controls.title}</h2>
    </div>

    <div class="plab__actions">
      {
        page.controls.actions.map((action) => (
          <button
            class={`plab__button ${action.primary ? 'is-primary' : ''}`}
            type="button"
            data-action={action.id}
            data-running-label={action.runningLabel}
            data-paused-label={action.pausedLabel}
          >
            <i class={`ph ${action.icon}`} aria-hidden="true"></i>
            <span>{action.label}</span>
          </button>
        ))
      }
    </div>

    {
      page.controls.presets && (
        <div class="plab__presets">
          {
            page.controls.presets.map((preset) => (
              <button class="plab__preset" type="button" data-preset={preset.id}>
                {preset.label}
              </button>
            ))
          }
        </div>
      )
    }

    {
      page.controls.toggles?.map((toggle) => (
        <label class="plab__toggle">
          <input type="checkbox" data-control={toggle.id} checked={toggle.checked} />
          <span>
            <strong>{toggle.label}</strong>
            <small>{toggle.description}</small>
          </span>
        </label>
      ))
    }

    {
      page.controls.fields?.map((field) => (
        <label class="plab__field">
          <span class="plab__field-label">
            <span class="plab__field-name">
              <span>{field.label}</span>
              {field.symbolLatex && <MathFormula expression={field.symbolLatex} />}
            </span>
            <output data-output={field.id}>{field.outputValue}</output>
          </span>
          <input
            type="range"
            min={field.min}
            max={field.max}
            step={field.step}
            value={field.value}
            data-control={field.id}
          />
        </label>
      ))
    }

    {
      page.controls.notices?.map((notice) => (
        <p class="plab__notice">
          <i class={`ph ${notice.icon}`} aria-hidden="true"></i>
          <span>{notice.text}</span>
        </p>
      ))
    }
  </form>
</PhysicsLabShell>
