---
import './ad-tracking-constraint-lab.css';
import AdTrackingArchitectureDiagram from './AdTrackingArchitectureDiagram.astro';
import { getSystemDesignArticleHref } from '../../scripts/system-design-lab/system-design-article-links';

const workloadControls = [
  {
    id: 'eventsPerSecond',
    label: '常态事件速率',
    help: '流量尖峰前，每秒到达的 click 和 impression。',
    min: 50,
    max: 500_000,
    defaultValue: 300,
    scale: 'log',
    unit: '/s',
  },
  {
    id: 'peakMultiplier',
    label: '峰值倍数',
    help: '上线、竞价、bot 突发和 retry 风暴会把流量压进很短的时间窗里。',
    min: 1,
    max: 30,
    defaultValue: 1.5,
    scale: 'linear',
    unit: 'x',
  },
  {
    id: 'reportingQueriesPerMinute',
    label: '报表查询',
    help: 'dashboard、广告主报表、billing 核对和分析师查询。',
    min: 1,
    max: 5_000,
    defaultValue: 12,
    scale: 'log',
    unit: '/min',
  },
  {
    id: 'retentionDays',
    label: '原始数据保留',
    help: '原始 event 需要保持可查询或可 replay 多久。',
    min: 1,
    max: 365,
    defaultValue: 7,
    scale: 'linear',
    unit: '天',
  },
  {
    id: 'hotCampaignShare',
    label: '最热 campaign 占比',
    help: '最大 campaign 占的流量份额，用来观察 hot partition 风险。',
    min: 1,
    max: 80,
    defaultValue: 5,
    scale: 'linear',
    unit: '%',
  },
  {
    id: 'freshnessSeconds',
    label: '指标新鲜度目标',
    help: 'counter、billing 候选值或风控信号需要多快更新。',
    min: 5,
    max: 3600,
    defaultValue: 900,
    scale: 'log',
    unit: 'sec',
  },
  {
    id: 'duplicatePercent',
    label: 'retry / 重复率',
    help: '客户端 retry 和 collector retry 会产生重复 event，需要 idempotency 处理。',
    min: 0,
    max: 20,
    defaultValue: 0.4,
    scale: 'linear',
    unit: '%',
  },
];

const scenarios = [
  {
    id: 'demo',
    step: '01',
    title: 'Demo 流量',
    summary: '一个 collector 加一个 database 还够用。',
  },
  {
    id: 'growth',
    step: '02',
    title: '产品增长',
    summary: '第一个压力是单机容量，于是 collector 横向扩展。',
  },
  {
    id: 'db-pressure',
    step: '03',
    title: '报表冲击写入',
    summary: '共享 database 的争用逼出一条「先 append」的 pipeline。',
  },
  {
    id: 'launch-spike',
    step: '04',
    title: '上线尖峰',
    summary: '峰值流量和新鲜度要求让 partitioning 和 streaming 变得必要。',
  },
  {
    id: 'billing-realtime',
    step: '05',
    title: 'Billing 实时',
    summary: '审计、replay、hot partition 和 serving view 全都要上。',
  },
];

const bottleneckMeters = [
  ['singleHost', '单机 ingest'],
  ['sharedDatabase', '共享 DB 压力'],
  ['storage', '原始数据存储'],
  ['hotPartition', 'Hot partition'],
  ['freshness', '新鲜度压力'],
];

const decisionCards = [
  ['multiHost', '多机 collector'],
  ['sharedDatabase', '共享 database'],
  ['eventLog', '持久化 event log'],
  ['partitioning', 'Partitioning'],
  ['streaming', 'Stream 聚合'],
  ['servingStores', 'Serving store'],
];

const sourceBackedRules = [
  {
    title: 'Partition 能扩 throughput，但 ordering 只在 partition 内成立',
    source: 'Apache Kafka docs',
    url: 'https://kafka.apache.org/documentation/',
    summary:
      'Kafka 的 topic 会切成多个 partition 分布在 broker 上；consumer 只在单个 topic-partition 内看到有序的 event。这就是本 lab 把 partition key 既当扩展手段、又当 ordering 取舍的原因。',
  },
  {
    title: '持久化 queue 和 stream 把故障与 back pressure 解耦',
    source: 'AWS Well-Architected',
    url: 'https://docs.aws.amazon.com/wellarchitected/latest/framework/rel_prevent_interaction_failure_loosely_coupled_system.html',
    summary:
      'queue 和 streaming 系统把 producer 和 consumer 隔开，让各组件独立扩展或独立失败。当直写开始把 ingest 和报表耦在一起时，这支撑了引入 event log 这一步。',
  },
  {
    title: '实时 window 需要 event time、watermark 和 late-event 策略',
    source: 'Apache Flink docs',
    url: 'https://nightlies.apache.org/flink/flink-docs-stable/docs/concepts/time/',
    summary:
      'Flink 用 watermark 追踪 event-time 的进度，迟到或乱序的 event 会逼出 latency 与正确性之间的取舍。这支撑了本 lab 里 streaming 和新鲜度的部分。',
  },
  {
    title: '实时 analytics 本质是 event-stream 的 serving 问题',
    source: 'ClickHouse docs',
    url: 'https://clickhouse.com/docs/cloud/get-started/cloud/use-cases/real-time-analytics',
    summary:
      '实时 analytics 系统在 event 产生后很快就从 event stream 里提炼洞察。这就是随着读压力上升，dashboard/risk/billing view 应该从原始 ingest 路径里拆出来的原因。',
  },
];

const teachingAssumptions = [
  '滑块里的容量数字是教学阈值，不是生产环境的 benchmark。',
  '真实容量取决于 payload 大小、batching、replication、acks、index、查询形态、磁盘、网络以及运维 SLO。',
  '这个 lab 最适合用来做面试推演：先给出最简单的设计，再点名那个逼你加下一个组件的具体约束。',
];
const articleHref = getSystemDesignArticleHref('ad-tracking');
---

<section class="system-lab" id="ad-tracking" data-system-design-lab>
  <div class="system-lab__intro">
    <p class="system-lab__eyebrow">系统设计 Lab</p>
    <h1 class="system-lab__title">Ad tracking 架构只在约束逼它变时才变。</h1>
    <p class="system-lab__summary">
      从最简单的 click/impression collector 开始。用这些 scenario 走一条常规的演化路径，再调
      workload，看清楚单机、单个共享 database、或单个 partition 究竟在什么时候不再是好答案。
    </p>
    <div class="system-lab__intro-actions">
      <a href={articleHref}>阅读完整教程</a>
    </div>
  </div>

  <section class="system-lab__scenarios" aria-label="常规架构演化 scenario">
    <div class="system-lab__scenarios-header">
      <h2>常规演化 scenario</h2>
      <p>从左到右点，就是设计好的 demo 路径。每张卡片都会改 workload 输入。</p>
    </div>
    <div class="system-lab__scenario-grid">
      {
        scenarios.map((scenario) => (
          <button
            class="system-lab__scenario"
            type="button"
            data-scenario-button
            data-scenario-id={scenario.id}
            aria-pressed={scenario.id === 'demo' ? 'true' : 'false'}
          >
            <span>{scenario.step}</span>
            <strong>{scenario.title}</strong>
            <small>{scenario.summary}</small>
          </button>
        ))
      }
    </div>
  </section>

  <div class="system-lab__workspace">
    <form class="system-lab__controls" aria-label="Workload 控制项">
      <div class="system-lab__controls-header">
        <h2>Workload</h2>
        <p>这些是输入，不是预设好的架构阶段。</p>
      </div>

      {
        workloadControls.map((control) => (
          <label class="system-lab__control" for={`lab-${control.id}`}>
            <span class="system-lab__control-label">
              <span>{control.label}</span>
              <output data-control-output={control.id}></output>
            </span>
            <input
              id={`lab-${control.id}`}
              type="range"
              min="0"
              max="100"
              step="1"
              data-control={control.id}
              data-min-value={control.min}
              data-max-value={control.max}
              data-default-value={control.defaultValue}
              data-scale={control.scale}
              data-unit={control.unit}
            />
            <span class="system-lab__control-help">{control.help}</span>
          </label>
        ))
      }

      <label class="system-lab__toggle">
        <input type="checkbox" data-control="billingGrade" />
        <span>
          <strong>Billing-grade 持久性</strong>
          <small>每个被接收的 event 都必须可 replay、可审计。</small>
        </span>
      </label>
    </form>

    <div class="system-lab__main">
      <div class="system-lab__verdict">
        <p class="system-lab__eyebrow">推荐形态</p>
        <h2 data-architecture-title>单机 collector</h2>
        <p data-architecture-summary>
          当 workload 还能塞进一台机器时，把 ingest、校验和存储放在一起。
        </p>
      </div>

      <div class="system-lab__diagram" aria-label="计算得出的架构图">
        <div class="system-lab__diagram-caption">
          <span>当前架构路径</span>
          <strong data-architecture-path>Ad events -> single collector -> shared database</strong>
        </div>

        <AdTrackingArchitectureDiagram locale="zh" />

        <div class="system-lab__mobile-flow" aria-label="计算得出的移动端架构流程">
          <div class="system-lab__mobile-stage">
            <span>Clients</span>
            <div class="system-lab__mobile-node" data-mobile-node="source">
              <strong>Client</strong>
              <small>ad server 发出 click/impression event</small>
            </div>
          </div>

          <div class="system-lab__mobile-stage">
            <span>Edge / API</span>
            <div class="system-lab__mobile-node" data-mobile-node="loadBalancer">
              <strong>Load balancer</strong>
              <small>主机扩展后做 fanout 和健康检查</small>
            </div>
            <div class="system-lab__mobile-node" data-mobile-node="collectors">
              <strong>Collector 服务</strong>
              <small>校验、dedupe key，接收 event</small>
            </div>
          </div>

          <div class="system-lab__mobile-stage">
            <span>Event backbone</span>
            <div class="system-lab__mobile-node" data-mobile-node="eventLog">
              <strong>持久化 event log</strong>
              <small>缓冲、replay，并让 consumer 解耦</small>
            </div>
            <div class="system-lab__mobile-node" data-mobile-node="partitioning">
              <strong>Partition key</strong>
              <small>按 campaign 还是 bucket 决定 ordering 和热点</small>
            </div>
          </div>

          <div class="system-lab__mobile-stage">
            <span>处理</span>
            <div class="system-lab__mobile-node" data-mobile-node="streaming">
              <strong>Stream worker</strong>
              <small>window、dedupe、counter，以及 late-event 策略</small>
            </div>
          </div>

          <div class="system-lab__mobile-stage">
            <span>存储 + serving</span>
            <div class="system-lab__mobile-node" data-mobile-node="sharedDatabase">
              <strong>Primary DB</strong>
              <small>负载还小时，简单存原始数据和报表</small>
            </div>
            <div class="system-lab__mobile-node" data-mobile-node="servingStores">
              <strong>Serving store</strong>
              <small>OLAP、billing、dashboard 和 risk view</small>
            </div>
            <div class="system-lab__mobile-node" data-mobile-node="warehouse">
              <strong>Warehouse</strong>
              <small>离线真值、保留、审计和 replay 核对</small>
            </div>
          </div>
        </div>
      </div>

      <div class="system-lab__analysis-grid">
        <section class="system-lab__panel">
          <h3>瓶颈</h3>
          <div class="system-lab__meters">
            {
              bottleneckMeters.map(([meterId, meterLabel]) => (
                <div class="system-lab__meter">
                  <div class="system-lab__meter-label">
                    <span>{meterLabel}</span>
                    <span data-meter-value={meterId}></span>
                  </div>
                  <span class="system-lab__meter-track" aria-hidden="true">
                    <span class="system-lab__meter-fill" data-meter={meterId}></span>
                  </span>
                  <p data-meter-copy={meterId}></p>
                </div>
              ))
            }
          </div>
        </section>

        <section class="system-lab__panel">
          <h3>为什么会变</h3>
          <ul class="system-lab__reasons" data-reasons></ul>
        </section>
      </div>

      <section class="system-lab__panel">
        <h3>决策取舍</h3>
        <div class="system-lab__decision-grid">
          {
            decisionCards.map(([cardId, cardTitle]) => (
              <article class="system-lab__decision" data-decision={cardId}>
                <span>{cardTitle}</span>
                <p data-decision-copy={cardId}></p>
              </article>
            ))
          }
        </div>
      </section>

      <section class="system-lab__panel system-lab__knowledge">
        <div class="system-lab__knowledge-header">
          <h3>有出处的规则</h3>
          <p>
            这些是模型背后那些经得起推敲的系统设计结论。而滑块上具体的阈值，是被刻意标注成教学假设的。
          </p>
        </div>

        <div class="system-lab__rule-grid">
          {
            sourceBackedRules.map((rule) => (
              <article class="system-lab__rule-card">
                <span>已验证规则</span>
                <h4>{rule.title}</h4>
                <p>{rule.summary}</p>
                <a href={rule.url} target="_blank" rel="noreferrer">
                  {rule.source}
                </a>
              </article>
            ))
          }
        </div>

        <div class="system-lab__assumptions">
          <h4>教学假设</h4>
          <ul>
            {teachingAssumptions.map((assumption) => <li>{assumption}</li>)}
          </ul>
        </div>
      </section>
    </div>
  </div>

  <script>
    import { initAdTrackingConstraintLab } from '../../scripts/system-design-lab/ad-tracking-constraint-lab';

    initAdTrackingConstraintLab();
  </script>
</section>
