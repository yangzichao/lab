---
import './ad-tracking-constraint-lab.css';
import type { SystemDesignLabDefinition } from '../../scripts/system-design-lab/lab-types';
import {
  nodeDetailMarkup,
  nodeFillPrimitives,
  nodeGlyphMarkup,
  nodeKind,
  nodeOutlinePrimitives,
  nodeTextTop,
} from '../../scripts/system-design-lab/architecture-shapes';
import {
  roughFillMarkup,
  roughFlowMarkup,
  roughStrokeMarkup,
  roughZoneMarkup,
  seedFromString,
} from '../../scripts/system-design-lab/architecture-rough';
import { getSystemDesignLabUiCopy } from '../../scripts/system-design-lab/system-design-lab-copy';
import {
  normalizeSystemDesignLocale,
  type SystemDesignLocale,
} from '../../scripts/system-design-lab/system-design-i18n';

interface Props {
  lab: SystemDesignLabDefinition;
  locale?: SystemDesignLocale;
}

const { lab } = Astro.props;
const locale = normalizeSystemDesignLocale(Astro.props.locale);
const copy = getSystemDesignLabUiCopy(locale);
const flowMarkerId = `system-lab-arrow-${lab.id}`;

// Pre-render the hand-drawn (Excalidraw-style) geometry at build time.
const sketchedZones = lab.diagram.zones.map((zone) => ({
  ...zone,
  sketch: roughZoneMarkup(zone.x, zone.y, zone.width, zone.height, seedFromString(`${lab.id}-zone-${zone.id}`)),
}));

const sketchedFlows = lab.diagram.flows.map((flow) => ({
  ...flow,
  sketch: roughFlowMarkup(flow.path, seedFromString(`${lab.id}-flow-${flow.id}`)),
}));

const sketchedNodes = lab.diagram.nodes.map((node) => {
  const seed = seedFromString(`${lab.id}-node-${node.id}`);
  return {
    node,
    kind: nodeKind(node),
    textTop: nodeTextTop(node),
    fill: roughFillMarkup(nodeFillPrimitives(node), seed),
    stroke: roughStrokeMarkup(nodeOutlinePrimitives(node), seed),
    detail: nodeDetailMarkup(node),
    glyph: nodeGlyphMarkup(node),
  };
});
---

<section
  class="system-lab"
  id={lab.id}
  data-system-design-constraint-lab
  data-lab-id={lab.id}
  data-locale={locale}
>
  <div class="system-lab__intro">
    <p class="system-lab__eyebrow">{lab.eyebrow}</p>
    <h1 class="system-lab__title">{lab.title}</h1>
    <p class="system-lab__summary">{lab.summary}</p>
    {
      lab.articleHref && (
        <div class="system-lab__intro-actions">
          <a href={lab.articleHref}>{copy.readSourceArticle}</a>
        </div>
      )
    }
  </div>

  {
    lab.teachingWalkthrough && lab.teachingWalkthrough.length > 0 && (
      <section
        class="system-lab__walkthrough"
        data-walkthrough
        aria-label={copy.guidedWalkthroughAriaLabel(lab.title)}
      >
        <div class="system-lab__walkthrough-header">
          <div>
            <p class="system-lab__eyebrow">{copy.guidedWalkthroughEyebrow}</p>
            <h2>{copy.guidedWalkthroughTitle}</h2>
          </div>
          <div class="system-lab__walkthrough-progress">
            <span data-walkthrough-position />
            <span class="system-lab__walkthrough-dots" aria-hidden="true">
              {lab.teachingWalkthrough.map((step, stepIndex) => (
                <span class="system-lab__walkthrough-dot" data-walkthrough-dot={stepIndex}>
                  {step.step}
                </span>
              ))}
            </span>
          </div>
        </div>

        <div class="system-lab__walkthrough-body">
          <span class="system-lab__walkthrough-focus" data-walkthrough-focus />
          <p class="system-lab__walkthrough-question" data-walkthrough-question />
          <button
            type="button"
            class="system-lab__walkthrough-reveal-btn"
            data-walkthrough-reveal-btn
          >
            {copy.revealReasoning}
          </button>
          <div class="system-lab__walkthrough-reveal" data-walkthrough-reveal hidden>
            <p data-walkthrough-reveal-text />
            <p class="system-lab__walkthrough-takeaway">
              <span>{copy.takeaway}</span>
              <strong data-walkthrough-takeaway />
            </p>
          </div>
        </div>

        <div class="system-lab__walkthrough-footer">
          <p class="system-lab__walkthrough-hint">
            {copy.walkthroughHint}
          </p>
          <div class="system-lab__walkthrough-nav">
            <button type="button" data-walkthrough-prev>
              &larr; {copy.previousStep}
            </button>
            <button type="button" data-walkthrough-next>
              {copy.nextStep} &rarr;
            </button>
          </div>
        </div>
      </section>
    )
  }

  <section class="system-lab__scenarios" aria-label={copy.scenariosAriaLabel(lab.title)}>
    <div class="system-lab__scenarios-header">
      <h2>{copy.scenariosTitle}</h2>
      <p>{copy.scenariosDescription}</p>
    </div>
    <div class="system-lab__scenario-grid">
      {
        lab.scenarios.map((scenario, scenarioIndex) => (
          <button
            class="system-lab__scenario"
            type="button"
            data-scenario-button
            data-scenario-id={scenario.id}
            aria-pressed={scenarioIndex === 0 ? 'true' : 'false'}
          >
            <span>{scenario.step}</span>
            <strong>{scenario.title}</strong>
            <small>{scenario.summary}</small>
          </button>
        ))
      }
    </div>
  </section>

  <div class="system-lab__workspace">
    <form class="system-lab__controls" aria-label={copy.controlsAriaLabel(lab.title)}>
      <div class="system-lab__controls-header">
        <h2>Workload</h2>
        <p>{copy.controlsDescription}</p>
      </div>

      {
        lab.controls.map((control) => (
          <label class="system-lab__control" for={`${lab.id}-${control.id}`}>
            <span class="system-lab__control-label">
              <span>{control.label}</span>
              <output data-control-output={control.id}></output>
            </span>
            <input
              id={`${lab.id}-${control.id}`}
              type="range"
              min="0"
              max="100"
              step="1"
              data-control={control.id}
            />
            <span class="system-lab__control-help">{control.help}</span>
          </label>
        ))
      }

      {
        lab.toggles.map((toggle) => (
          <label class="system-lab__toggle">
            <input type="checkbox" data-toggle-control={toggle.id} checked={toggle.defaultValue} />
            <span>
              <strong>{toggle.label}</strong>
              <small>{toggle.help}</small>
            </span>
          </label>
        ))
      }
    </form>

    <div class="system-lab__main">
      <div class="system-lab__verdict">
        <p class="system-lab__eyebrow">{copy.recommendedShape}</p>
        <h2 data-architecture-title></h2>
        <p data-architecture-summary></p>
      </div>

      <div class="system-lab__diagram" aria-label={copy.diagramAriaLabel}>
        <div class="system-lab__diagram-caption">
          <span>{copy.architecturePath}</span>
          <strong data-architecture-path></strong>
        </div>

        <svg
          class="system-lab__sketch"
          viewBox={lab.diagram.viewBox}
          role="img"
          aria-labelledby={`${lab.id}-sketch-title ${lab.id}-sketch-description`}
          style={`--system-lab-flow-marker: url('#${flowMarkerId}')`}
        >
          <title id={`${lab.id}-sketch-title`}>{lab.diagram.title}</title>
          <desc id={`${lab.id}-sketch-description`}>{lab.diagram.description}</desc>

          <defs>
            <marker
              id={flowMarkerId}
              viewBox="0 0 12 12"
              refX="9"
              refY="6"
              markerWidth="9"
              markerHeight="9"
              orient="auto-start-reverse"
            >
              <path class="system-lab__arrowhead" d="M2 2 L10 6 L2 10"></path>
            </marker>
          </defs>

          {
            sketchedZones.map((zone) => (
              <g class={`system-lab__sketch-zone system-lab__sketch-zone--${zone.variant ?? zone.id}`}>
                <g class="system-lab__zone-shape" set:html={zone.sketch} />
                <text x={zone.x + 16} y={zone.y + 28}>
                  {zone.label}
                </text>
              </g>
            ))
          }

          <g class="system-lab__sketch-flows">
            {
              sketchedFlows.map((flow) => (
                <g
                  class={`system-lab__sketch-flow-group system-lab__sketch-flow-group--${flow.variant ?? 'primary'}`}
                  data-flow={flow.id}
                  set:html={flow.sketch}
                />
              ))
            }
          </g>

          {
            sketchedNodes.map(({ node, kind, textTop, fill, stroke, detail, glyph }) => (
              <g
                class={`system-lab__sketch-node system-lab__sketch-node--${kind}`}
                data-node={node.id}
                data-kind={kind}
              >
                <g class="system-lab__rough-fill-group" set:html={fill} />
                <g class="system-lab__rough-stroke-group" set:html={stroke} />
                {detail && <g class="system-lab__shape-detail-group" set:html={detail} />}
                <g set:html={glyph} />
                <text x={node.x + node.width / 2} y={textTop} data-node-title={node.id}>
                  {node.title}
                </text>
                <text
                  x={node.x + node.width / 2}
                  y={textTop + 18}
                  class="system-lab__sketch-small"
                  data-node-copy={node.id}
                >
                  {node.subtitle}
                </text>
              </g>
            ))
          }
        </svg>

        <div class="system-lab__mobile-flow" aria-label={copy.mobileFlowAriaLabel}>
          {
            lab.diagram.mobileStages.map((stage) => (
              <div class="system-lab__mobile-stage">
                <span>{stage.label}</span>
                {stage.nodes.map((node) => (
                  <div class="system-lab__mobile-node" data-mobile-node={node.id}>
                    <strong>{node.title}</strong>
                    <small>{node.summary}</small>
                  </div>
                ))}
              </div>
            ))
          }
        </div>
      </div>

      <div class="system-lab__analysis-grid">
        <section class="system-lab__panel">
          <h3>{copy.bottlenecks}</h3>
          <div class="system-lab__meters">
            {
              lab.meters.map((meter) => (
                <div class="system-lab__meter">
                  <div class="system-lab__meter-label">
                    <span>{meter.label}</span>
                    <span data-meter-value={meter.id}></span>
                  </div>
                  <span class="system-lab__meter-track" aria-hidden="true">
                    <span class="system-lab__meter-fill" data-meter={meter.id}></span>
                  </span>
                  <p data-meter-copy={meter.id}></p>
                </div>
              ))
            }
          </div>
        </section>

        <section class="system-lab__panel">
          <h3>{copy.whyThisChanges}</h3>
          <ul class="system-lab__reasons" data-reasons></ul>
        </section>
      </div>

      <section class="system-lab__panel">
        <h3>{copy.decisionTradeoffs}</h3>
        <div class="system-lab__decision-grid">
          {
            lab.decisions.map((decision) => (
              <article class="system-lab__decision" data-decision={decision.id}>
                <span>{decision.title}</span>
                <p data-decision-copy={decision.id}></p>
              </article>
            ))
          }
        </div>
      </section>

      <section class="system-lab__panel system-lab__knowledge">
        <div class="system-lab__knowledge-header">
          <h3>{copy.sourceBackedRules}</h3>
          <p>{copy.sourceBackedRulesDescription}</p>
        </div>

        <div class="system-lab__rule-grid">
          {
            lab.sourceBackedRules.map((rule) => (
              <article class="system-lab__rule-card">
                <span>{copy.verifiedRule}</span>
                <h4>{rule.title}</h4>
                <p>{rule.summary}</p>
                <a href={rule.url} target="_blank" rel="noreferrer">
                  {rule.source}
                </a>
              </article>
            ))
          }
        </div>

        <div class="system-lab__assumptions">
          <h4>{copy.teachingAssumptions}</h4>
          <ul>
            {lab.teachingAssumptions.map((assumption) => <li>{assumption}</li>)}
          </ul>
        </div>
      </section>
    </div>
  </div>

  <script>
    import { initSystemDesignConstraintLabs } from '../../scripts/system-design-lab/system-design-constraint-lab';

    initSystemDesignConstraintLabs();
  </script>
</section>
